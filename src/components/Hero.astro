---
---

<section id="hero" class="relative overflow-hidden py-24 sm:py-32 flex items-center min-h-[calc(100vh-4rem)]">
  
  <!-- Glowing background elements for visual depth -->
  <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
    <div class="relative left-[calc(50%-11rem)] aspect-1155/678 w-[36rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-teal-500 to-emerald-400 opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72rem]"></div>
  </div>
  
  <div class="absolute inset-x-0 bottom-0 -z-10 transform-gpu overflow-hidden blur-3xl" aria-hidden="true">
    <div class="relative left-[calc(50%+11rem)] aspect-1155/678 w-[36rem] -translate-x-1/2 bg-gradient-to-br from-teal-400 to-indigo-500 opacity-15 sm:left-[calc(50%+30rem)] sm:w-[72rem]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Text Content -->
      <div class="lg:col-span-8 space-y-6 animate-fade-in-up">
        
        <!-- Welcome Badge -->
        <div class="inline-flex items-center gap-2 rounded-full border border-teal-500/20 bg-teal-500/5 px-3 py-1 text-xs sm:text-sm font-medium text-teal-800 dark:text-teal-300">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
          </span>
          Available for Opportunities
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold font-display tracking-tight leading-none">
          Hi, I am <br class="sm:hidden" />
          <span class="bg-gradient-to-r from-teal-600 via-emerald-500 to-teal-400 bg-clip-text text-transparent dark:from-teal-400 dark:via-teal-300 dark:to-emerald-400">
            Leong Kah Yung
          </span>
        </h1>

        <p class="text-xl sm:text-2xl font-semibold text-slate-800 dark:text-slate-200">
          Software Engineering Student &amp; Developer
        </p>

        <p class="max-w-xl text-base sm:text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
          I build scalable backend applications and modern full-stack systems. Specialized in Java, Spring Boot, Angular, and RESTful APIs, with hands-on experience in financial technology integration and Agile engineering.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 pt-4">
          <a
            href="/resume.pdf"
            download="Leong_Kah_Yung_Resume.pdf"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-teal-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-teal-500/20 hover:bg-teal-500 hover:shadow-teal-500/30 dark:bg-teal-500 dark:text-slate-950 dark:shadow-none dark:hover:bg-teal-400 focus:outline-none focus:ring-2 focus:ring-teal-500/50 transition-all duration-300 transform hover:-translate-y-0.5"
          >
            <!-- Download Icon -->
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download Resume
          </a>
          
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-300 bg-white/50 px-6 py-3.5 text-base font-semibold text-slate-800 hover:bg-slate-100 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-200 dark:hover:bg-slate-800/80 focus:outline-none focus:ring-2 focus:ring-teal-500/50 transition-all duration-300 transform hover:-translate-y-0.5"
          >
            Contact Me
          </a>
        </div>

        <!-- Social Icons -->
        <div class="flex items-center gap-5 pt-6">
          <a
            href="https://github.com/Yung729"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-600 hover:text-teal-600 dark:text-slate-400 dark:hover:text-teal-400 transition-colors duration-200"
            aria-label="GitHub Profile"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
          </a>

          <a
            href="https://linkedin.com/in/kah-yung-leong5b9b6427b"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-600 hover:text-teal-600 dark:text-slate-400 dark:hover:text-teal-400 transition-colors duration-200"
            aria-label="LinkedIn Profile"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/>
            </svg>
          </a>

          <a
            href="mailto:leongkahyung@gmail.com"
            class="text-slate-600 hover:text-teal-600 dark:text-slate-400 dark:hover:text-teal-400 transition-colors duration-200"
            aria-label="Email Contact"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>

      </div>

      <!-- Hero Visual Art / Graphic Card (Premium Look) -->
      <div class="lg:col-span-4 flex justify-center lg:justify-end animate-fade-in animation-delay-200">
        <div class="relative w-72 h-72 sm:w-80 sm:h-80 lg:w-96 lg:h-96 group">
          
          <!-- Outer decorative rotating border/glow -->
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-tr from-teal-500 to-emerald-400 opacity-20 blur-xl group-hover:opacity-35 transition-opacity duration-300"></div>
          
          <!-- Card Base -->
          <div class="absolute inset-0 rounded-3xl border border-slate-200 dark:border-slate-800 glass-card p-6 flex flex-col justify-between overflow-hidden shadow-2xl transition-all duration-300 group-hover:translate-y-[-4px]">
            
            <!-- Graphic Design -->
            <div class="flex justify-between items-start">
              <div class="h-10 w-10 rounded-xl bg-teal-500/10 dark:bg-teal-400/15 flex items-center justify-center text-teal-600 dark:text-teal-300">
                <code class="font-bold text-lg">&lt;/&gt;</code>
              </div>
              <span class="text-xs font-mono text-slate-400 dark:text-slate-500">System.out.println("Hello");</span>
            </div>

            <!-- Conceptual Design Visuals (Code lines visual representation) -->
            <div class="space-y-4 my-8">
              <div class="h-2 w-3/4 rounded-full bg-slate-300 dark:bg-slate-700"></div>
              <div class="h-2 w-full rounded-full bg-gradient-to-r from-teal-500 to-emerald-400"></div>
              <div class="h-2 w-5/6 rounded-full bg-slate-300 dark:bg-slate-700"></div>
              <div class="h-2 w-2/3 rounded-full bg-slate-300 dark:bg-slate-700"></div>
            </div>

            <!-- Stats/Footer of Card -->
            <div class="flex items-center justify-between border-t border-slate-200/50 dark:border-slate-800/50 pt-4">
              <div>
                <p class="text-xs text-slate-400 dark:text-slate-500">Specialization</p>
                <p class="text-sm font-semibold text-slate-800 dark:text-slate-200">Backend &amp; Cloud</p>
              </div>
              <div class="text-right">
                <p class="text-xs text-slate-400 dark:text-slate-500">Experience</p>
                <p class="text-sm font-semibold text-slate-800 dark:text-slate-200">2 Internships</p>
              </div>
            </div>
            
          </div>
          
        </div>
      </div>

    </div>
  </div>
</section>
