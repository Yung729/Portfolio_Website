<section id="hero" class="relative overflow-hidden py-24 sm:py-32 flex items-center min-h-[calc(100vh-4rem)]">
  
  <!-- Glowing background elements for visual depth -->
  <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
    <div class="relative left-[calc(50%-11rem)] aspect-1155/678 w-[36rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-teal-500 to-emerald-400 opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72rem]"></div>
  </div>
  
  <div class="absolute inset-x-0 bottom-0 -z-10 transform-gpu overflow-hidden blur-3xl" aria-hidden="true">
    <div class="relative left-[calc(50%+11rem)] aspect-1155/678 w-[36rem] -translate-x-1/2 bg-gradient-to-br from-teal-400 to-indigo-500 opacity-15 sm:left-[calc(50%+30rem)] sm:w-[72rem]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Text Content -->
      <div class="lg:col-span-7 space-y-6 animate-fade-in-up">
        
        <!-- Welcome Badge -->
        <div class="inline-flex items-center gap-2 rounded-full border border-teal-500/20 bg-teal-500/5 px-3 py-1 text-xs sm:text-sm font-medium text-teal-800 dark:text-teal-300">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
          </span>
          Available for Opportunities
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold font-display tracking-tight leading-none">
          Hi, I am <br class="sm:hidden" />
          <span class="bg-gradient-to-r from-teal-600 via-emerald-500 to-teal-400 bg-clip-text text-transparent dark:from-teal-400 dark:via-teal-300 dark:to-emerald-400">
            Leong Kah Yung
          </span>
        </h1>

        <p class="text-xl sm:text-2xl font-semibold text-slate-800 dark:text-slate-200 min-h-[40px] flex items-center">
          <span id="typewriter-text" class="text-teal-600 dark:text-teal-400"></span><span class="animate-pulse text-teal-600 dark:text-teal-400 font-extrabold ml-1">|</span>
        </p>

        <p class="max-w-xl text-base sm:text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
          I build scalable backend applications and modern full-stack systems. Specialized in Java, Spring Boot, Angular, and RESTful APIs, with hands-on experience in financial technology integration and Agile engineering.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 pt-4">
          <a
            href="/resume.pdf"
            download="Leong_Kah_Yung_Resume.pdf"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-teal-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-teal-500/20 hover:bg-teal-500 hover:shadow-teal-500/30 dark:bg-teal-500 dark:text-slate-950 dark:shadow-none dark:hover:bg-teal-400 focus:outline-none focus:ring-2 focus:ring-teal-500/50 transition-all duration-300 transform hover:-translate-y-0.5"
          >
            <!-- Download Icon -->
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download Resume
          </a>
          
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-300 bg-white/50 px-6 py-3.5 text-base font-semibold text-slate-800 hover:bg-slate-100 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-200 dark:hover:bg-slate-800/80 focus:outline-none focus:ring-2 focus:ring-teal-500/50 transition-all duration-300 transform hover:-translate-y-0.5"
          >
            Contact Me
          </a>
        </div>

        <!-- Social Icons -->
        <div class="flex items-center gap-5 pt-6">
          <a
            href="https://github.com/Yung729"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-600 hover:text-teal-600 dark:text-slate-400 dark:hover:text-teal-400 transition-colors duration-200"
            aria-label="GitHub Profile"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
          </a>

          <a
            href="https://www.linkedin.com/in/kahyung"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-600 hover:text-teal-600 dark:text-slate-400 dark:hover:text-teal-400 transition-colors duration-200"
            aria-label="LinkedIn Profile"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/>
            </svg>
          </a>

          <a
            href="mailto:leongkahyung@gmail.com"
            class="text-slate-600 hover:text-teal-600 dark:text-slate-400 dark:hover:text-teal-400 transition-colors duration-200"
            aria-label="Email Contact"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>

      </div>

      <!-- Hero Terminal Widget (Premium Interactive CLI) -->
      <div class="lg:col-span-5 w-full flex justify-center lg:justify-end animate-fade-in animation-delay-200">
        <div class="relative w-full max-w-lg rounded-2xl border border-slate-200 dark:border-slate-800 bg-slate-950 text-slate-100 shadow-2xl overflow-hidden flex flex-col font-mono text-xs sm:text-sm h-[380px] group transition-all duration-300 hover:border-teal-500/50">
          
          <!-- Outer decorative glow -->
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-tr from-teal-500 to-emerald-400 opacity-5 blur-xl group-hover:opacity-10 transition-opacity duration-300 -z-10"></div>
          
          <!-- Terminal Header -->
          <div class="bg-slate-900 px-4 py-3 flex items-center justify-between border-b border-slate-850 select-none shrink-0">
            <!-- Window dots -->
            <div class="flex items-center gap-1.5">
              <span class="h-3 w-3 rounded-full bg-rose-500/80 hover:bg-rose-500 transition-colors cursor-pointer"></span>
              <span class="h-3 w-3 rounded-full bg-amber-500/80 hover:bg-amber-500 transition-colors cursor-pointer"></span>
              <span class="h-3 w-3 rounded-full bg-emerald-500/80 hover:bg-emerald-500 transition-colors cursor-pointer"></span>
            </div>
            
            <!-- Title -->
            <span class="text-xs text-slate-450 font-sans font-medium">leong@portfolio: ~</span>
            
            <!-- Shell Type / Speaker Toggle -->
            <div class="flex items-center gap-2">
              <button
                id="terminal-sound-toggle"
                class="text-slate-400 hover:text-teal-400 transition-colors p-0.5 rounded focus:outline-none cursor-pointer"
                title="Toggle terminal typing sounds"
              >
                <!-- Speaker Off Icon (default) -->
                <svg id="sound-off-icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
                </svg>
                <!-- Speaker On Icon (hidden by default) -->
                <svg id="sound-on-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
                </svg>
              </button>
              <span class="text-xxs px-1.5 py-0.5 rounded bg-slate-850 text-slate-400 font-sans">zsh</span>
            </div>
          </div>
          
          <!-- Terminal Body -->
          <div id="terminal-body" class="flex-1 p-4 overflow-y-auto space-y-2 select-text scrollbar-thin scrollbar-thumb-slate-800 scrollbar-track-transparent cursor-text">
            <!-- Static Welcome Output -->
            <div class="text-slate-400 leading-relaxed text-xs">
              <p class="text-teal-400 font-semibold mb-1">Kah Yung's Interactive Portfolio CLI (v1.1.0)</p>
              <p class="text-slate-500">Type <span class="text-emerald-400 font-semibold">help</span> to view all available commands.</p>
            </div>
            
            <!-- Dynamic Command Log -->
            <div id="terminal-output" class="space-y-2"></div>
            
            <!-- User Prompt Line -->
            <div class="flex items-center gap-1.5 pt-1">
              <span class="text-teal-400 shrink-0">kahyung@portfolio:~$</span>
              <input
                id="terminal-input"
                type="text"
                class="bg-transparent border-none outline-none focus:ring-0 p-0 text-slate-100 flex-1 caret-teal-400 focus:outline-none w-full"
                aria-label="Terminal prompt input"
                autocomplete="off"
                autocorrect="off"
                autocapitalize="off"
                spellcheck="false"
              />
            </div>
          </div>
          
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // --- Typewriter Effect ---
  const words = [
    "Software Engineering Student",
    "Backend & API Developer",
    "Java & Spring Boot Specialist",
    "Full-Stack Builder"
  ];
  
  let wordIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const typewriterText = document.getElementById('typewriter-text');
  
  const type = () => {
    const currentWord = words[wordIndex];
    if (isDeleting) {
      charIndex--;
    } else {
      charIndex++;
    }
    
    if (typewriterText) {
      typewriterText.textContent = currentWord.substring(0, charIndex);
    }
    
    let typeSpeed = isDeleting ? 40 : 80;
    
    if (!isDeleting && charIndex === currentWord.length) {
      typeSpeed = 2000; // Hold at full word
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      wordIndex = (wordIndex + 1) % words.length;
      typeSpeed = 400; // Pause before next word
    }
    
    setTimeout(type, typeSpeed);
  };
  
  // Start typewriter on load
  if (typewriterText) {
    setTimeout(type, 1000);
  }

  // --- Terminal Interactive CLI ---
  const terminalInput = document.getElementById('terminal-input') as HTMLInputElement;
  const terminalBody = document.getElementById('terminal-body');
  const terminalOutput = document.getElementById('terminal-output');
  const soundToggleBtn = document.getElementById('terminal-sound-toggle');
  const soundOffIcon = document.getElementById('sound-off-icon');
  const soundOnIcon = document.getElementById('sound-on-icon');

  let isAudioEnabled = false;

  // Sound Synth Functions
  const playClickSound = () => {
    if (!isAudioEnabled) return;
    try {
      const AudioCtx = window.AudioContext || (window as any).webkitAudioContext;
      const ctx = new AudioCtx();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(350 + Math.random() * 150, ctx.currentTime);
      
      gain.gain.setValueAtTime(0.04, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.04);
      
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.start();
      osc.stop(ctx.currentTime + 0.04);
    } catch (e) {
      console.warn('Web Audio API not supported or blocked:', e);
    }
  };

  const playSuccessSound = () => {
    if (!isAudioEnabled) return;
    try {
      const AudioCtx = window.AudioContext || (window as any).webkitAudioContext;
      const ctx = new AudioCtx();
      
      const playNote = (freq: number, delay: number, duration: number) => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq, ctx.currentTime + delay);
        gain.gain.setValueAtTime(0, ctx.currentTime + delay);
        gain.gain.linearRampToValueAtTime(0.08, ctx.currentTime + delay + 0.05);
        gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + delay + duration);
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.start(ctx.currentTime + delay);
        osc.stop(ctx.currentTime + delay + duration);
      };
      
      playNote(523.25, 0.0, 0.25); // C5
      playNote(659.25, 0.08, 0.25); // E5
      playNote(783.99, 0.16, 0.35); // G5
      playNote(1046.50, 0.24, 0.55); // C6
    } catch (e) {
      console.warn(e);
    }
  };

  // Toggle Sound
  soundToggleBtn?.addEventListener('click', (e) => {
    e.stopPropagation(); // Avoid triggering terminalBody click focus
    isAudioEnabled = !isAudioEnabled;
    if (isAudioEnabled) {
      soundOffIcon?.classList.add('hidden');
      soundOnIcon?.classList.remove('hidden');
      // Play a quick test click so user knows it works
      playClickSound();
    } else {
      soundOffIcon?.classList.remove('hidden');
      soundOnIcon?.classList.add('hidden');
    }
  });

  const commands: Record<string, (args?: string[]) => string> = {
    help: () => `Available commands:<br>  <span class="text-teal-400">about</span>    - Introduce myself<br>  <span class="text-teal-400">skills</span>   - List my technical stack<br>  <span class="text-teal-400">projects</span> - Highlight recent projects<br>  <span class="text-teal-400">contact</span>  - Get my contact channels<br>  <span class="text-teal-400">clear</span>    - Clear terminal screen<br>  <span class="text-teal-400">sudo</span>     - Run high privilege command`,
    about: () => `Hi, I'm Leong Kah Yung, a Software Engineering student at APU (Asia Pacific University). I focus on build scalability, robust backend logic with Java & Spring Boot, and modern user interfaces.`,
    skills: () => `<span class="text-teal-400">[Languages]</span> Java, Kotlin, JS/TS, SQL, HTML/CSS<br><span class="text-teal-400">[Frameworks]</span> Spring Boot, Angular, Flask, Astro, Android SDK<br><span class="text-teal-400">[Tools/Cloud]</span> AWS (S3, DynamoDB, SageMaker), Git, Firebase, REST APIs`,
    projects: () => `1. <span class="text-emerald-400 font-semibold">Vision-Based Smart Retail Billing System</span> (YOLOv8, Flask, AWS)<br>2. <span class="text-emerald-400 font-semibold">Blindmate Voice-Assistive Android App</span> (Kotlin, Gemini API)<br>Check them out in the Projects section below!`,
    contact: () => `Email:    <a href="mailto:leongkahyung@gmail.com" class="underline hover:text-teal-400">leongkahyung@gmail.com</a><br>Phone:    +60 11-2459 0628<br>GitHub:   <a href="https://github.com/Yung729" target="_blank" class="underline hover:text-teal-400">github.com/Yung729</a><br>LinkedIn: <a href="https://www.linkedin.com/in/kahyung" target="_blank" class="underline hover:text-teal-400">linkedin.com/in/kahyung</a>`,
    clear: () => {
      if (terminalOutput) terminalOutput.innerHTML = '';
      return '';
    },
    sudo: (args) => {
      if (args && args.join(' ') === 'get-hired') {
        setTimeout(() => {
          window.location.href = 'mailto:leongkahyung@gmail.com?subject=Job%20Opportunity%20-%20Hiring%20Offer';
        }, 2000);
        // Play victory chime!
        playSuccessSound();
        return `<span class="text-emerald-400 font-bold">Access Granted! Redirecting to mailto:leongkahyung@gmail.com in 2 seconds... 🚀</span>`;
      }
      return `Usage: <span class="text-teal-400">sudo get-hired</span>`;
    }
  };

  const handleCommand = (rawInput: string) => {
    const input = rawInput.trim();
    if (!input) return;

    const parts = input.split(' ');
    const cmd = parts[0].toLowerCase();
    const args = parts.slice(1);

    // Create command log
    const cmdLine = document.createElement('div');
    cmdLine.innerHTML = `<span class="text-teal-400">kahyung@portfolio:~$</span> <span class="text-slate-100">${input}</span>`;
    terminalOutput?.appendChild(cmdLine);

    // Execute
    let response = '';
    if (commands[cmd]) {
      response = commands[cmd](args);
    } else {
      response = `bash: command not found: <span class="text-rose-400">${cmd}</span>. Type <span class="text-teal-400">help</span> for options.`;
    }

    if (response) {
      const responseLine = document.createElement('div');
      responseLine.className = 'text-slate-400 whitespace-pre-wrap leading-relaxed';
      responseLine.innerHTML = response;
      terminalOutput?.appendChild(responseLine);
    }

    // Scroll to bottom
    setTimeout(() => {
      if (terminalBody) {
        terminalBody.scrollTop = terminalBody.scrollHeight;
      }
    }, 10);
  };

  // Event listeners
  terminalBody?.addEventListener('click', () => {
    terminalInput?.focus();
  });

  terminalInput?.addEventListener('keydown', (e) => {
    // Play clicking sound for regular typing keys
    if (e.key.length === 1 || e.key === 'Backspace' || e.key === 'Delete' || e.key === 'Enter') {
      playClickSound();
    }
    
    if (e.key === 'Enter') {
      const val = terminalInput.value;
      handleCommand(val);
      terminalInput.value = '';
    }
  });
</script>
