---
const experiences = [
  {
    role: "Intern, IT Partnership",
    company: "iFAST Global Hub AI Sdn. Bhd.",
    period: "Jan 2026 – Jul 2026",
    location: "Kuala Lumpur, Malaysia",
    highlights: [
      "Collaborated on development and integration of backend services supporting fintech application partners.",
      "Assisted in designing and testing secure RESTful APIs and documenting integration flows for cross-team alignment.",
      "Participated actively in Agile Scrum processes, code reviews, and quality assurance workflows to maintain system integrity."
    ]
  },
  {
    role: "Software Engineering Intern",
    company: "EasyPro Sdn Bhd",
    period: "Nov 2023 – Feb 2024",
    location: "Selangor, Malaysia",
    highlights: [
      "Contributed to database configurations, writing SQL scripts and optimizing structured tables.",
      "Assisted in full-stack feature modifications and bug resolution using HTML/CSS/JavaScript and backend frameworks.",
      "Supported product deployments, wrote thorough system documentation, and conducted manual verification testing."
    ]
  }
];
---

<section id="experience" class="py-20 sm:py-28 bg-slate-100/50 dark:bg-slate-900/30">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="mb-16">
      <h2 class="text-base font-semibold uppercase tracking-wider text-teal-600 dark:text-teal-400">Experience</h2>
      <p class="mt-2 text-3xl sm:text-4xl font-extrabold font-display tracking-tight text-slate-900 dark:text-white">Professional Journey</p>
      <div class="mt-4 h-1 w-12 rounded bg-teal-500"></div>
    </div>

    <!-- Timeline Layout -->
    <div class="relative max-w-3xl mx-auto">
      
      <!-- Center vertical line -->
      <div class="absolute left-4 sm:left-1/2 top-0 bottom-0 w-0.5 bg-slate-200 dark:bg-slate-800 -translate-x-1/2 hidden sm:block"></div>
      
      <!-- Left side line for mobile -->
      <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-slate-200 dark:bg-slate-800 -translate-x-1/2 block sm:hidden"></div>

      <!-- Experience Items -->
      <div class="space-y-12">
        {experiences.map((exp, idx) => (
          <div class={`relative flex flex-col sm:flex-row items-start ${idx % 2 === 0 ? 'sm:flex-row-reverse' : ''}`}>
            
            <!-- Timeline node / dot -->
            <div class="absolute left-4 sm:left-1/2 w-4 h-4 rounded-full bg-teal-500 border-4 border-slate-50 dark:border-slate-950 -translate-x-1/2 top-1.5 shadow z-10"></div>
            
            <!-- Width buffers for alternating layout -->
            <div class="w-full sm:w-1/2 pl-10 sm:pl-0 sm:px-8">
              <div class="rounded-2xl border border-slate-200 dark:border-slate-800/80 glass-card p-6 shadow-sm hover:shadow-md transition-shadow duration-300">
                
                <!-- Period and Location -->
                <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
                  <span class="inline-flex items-center rounded-full bg-teal-500/10 px-2.5 py-0.5 text-xs font-semibold text-teal-800 dark:text-teal-300">
                    {exp.period}
                  </span>
                  <span class="text-xs text-slate-400 dark:text-slate-500">
                    {exp.location}
                  </span>
                </div>

                <!-- Job Title & Company -->
                <h3 class="text-lg font-bold font-display text-slate-900 dark:text-white">{exp.role}</h3>
                <p class="text-sm font-semibold text-teal-600 dark:text-teal-400 mb-4">{exp.company}</p>

                <!-- Description Highlights -->
                <ul class="space-y-2.5 text-sm text-slate-600 dark:text-slate-400">
                  {exp.highlights.map((point) => (
                    <li class="flex items-start gap-2">
                      <svg class="h-4 w-4 text-teal-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>

              </div>
            </div>

            <!-- Empty element for grid balancing on desktop -->
            <div class="hidden sm:block sm:w-1/2"></div>
            
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
