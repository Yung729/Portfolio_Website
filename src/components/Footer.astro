---

<footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 py-12 transition-colors duration-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      
      <!-- Logo Signature -->
      <a href="#top" class="text-lg font-bold font-display tracking-tight text-slate-900 dark:text-white flex items-center gap-1 group">
        <span class="bg-gradient-to-r from-teal-600 to-emerald-500 bg-clip-text text-transparent group-hover:from-teal-500 group-hover:to-emerald-400 transition-colors duration-200">Kah Yung</span>
        <span class="text-slate-400 font-normal">| Portfolio</span>
      </a>

      <!-- Copyright -->
      <p class="text-sm text-slate-500 dark:text-slate-400 text-center md:order-last flex items-center gap-2">
        <span>&copy; {new Date().getFullYear()} Leong Kah Yung. All rights reserved.</span>
        <!-- Hidden admin entry — not labeled, just a subtle dot -->
        <button
          id="footer-admin-btn"
          class="text-slate-700 dark:text-slate-800 hover:text-slate-400 dark:hover:text-slate-600 transition-colors duration-200 text-base leading-none select-none"
          title=""
          aria-label="Admin"
        >·</button>
      </p>

      <!-- Socials & Top Scroll -->
      <div class="flex items-center gap-6">
        
        <!-- GitHub -->
        <a
          href="https://github.com/Yung729"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors duration-150"
          aria-label="GitHub Profile"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/kahyung"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors duration-150"
          aria-label="LinkedIn Profile"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/>
          </svg>
        </a>

        <!-- Back to top icon button -->
        <a
          href="#top"
          class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:text-slate-900 hover:border-slate-300 dark:border-slate-800 dark:text-slate-500 dark:hover:text-white dark:hover:border-slate-700 transition-all duration-150"
          aria-label="Back to Top"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
          </svg>
        </a>

      </div>

    </div>
  </div>
</footer>

<!-- Admin Password Modal (triggered by footer dot) -->
<div id="footer-admin-modal" class="fixed inset-0 bg-slate-950/70 backdrop-blur-sm z-[80] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-300">
  <div id="footer-admin-box" class="bg-slate-900 border border-slate-800 rounded-2xl w-full max-w-sm shadow-2xl p-6 transform scale-95 transition-all duration-300">
    <div class="text-center mb-6">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-teal-500/10 border border-teal-500/20 mb-3">
        <svg class="h-6 w-6 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
      </div>
      <h3 class="text-lg font-bold text-white font-display">Admin Access</h3>
    </div>
    <div class="space-y-4">
      <input
        id="footer-admin-password"
        type="password"
        placeholder="Enter password..."
        class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-500/20 transition-all duration-200"
      />
      <p id="footer-admin-error" class="text-rose-400 text-sm hidden">Incorrect password.</p>
      <div class="flex gap-3">
        <button id="footer-admin-cancel" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-700 text-slate-400 hover:text-white font-semibold text-sm transition-all duration-200">
          Cancel
        </button>
        <button id="footer-admin-submit" class="flex-1 px-4 py-2.5 rounded-xl bg-teal-600 hover:bg-teal-500 text-white font-semibold text-sm transition-all duration-200">
          Unlock
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const ADMIN_PASSWORD = 'NoLifeLiao0729$';
  const SESSION_KEY = 'ky_interview_auth';

  async function hashPassword(pw) {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(pw));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  const footerBtn    = document.getElementById('footer-admin-btn');
  const modal        = document.getElementById('footer-admin-modal');
  const modalBox     = document.getElementById('footer-admin-box');
  const pwInput      = document.getElementById('footer-admin-password');
  const errEl        = document.getElementById('footer-admin-error');
  const cancelBtn    = document.getElementById('footer-admin-cancel');
  const submitBtn    = document.getElementById('footer-admin-submit');

  function openAdminModal() {
    pwInput.value = '';
    errEl.classList.add('hidden');
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.classList.add('opacity-100', 'pointer-events-auto');
    modalBox.classList.remove('scale-95');
    modalBox.classList.add('scale-100');
    document.body.style.overflow = 'hidden';
    setTimeout(() => pwInput.focus(), 100);
  }

  function closeAdminModal() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.classList.remove('opacity-100', 'pointer-events-auto');
    modalBox.classList.add('scale-95');
    modalBox.classList.remove('scale-100');
    document.body.style.overflow = '';
  }

  async function handleAdminSubmit() {
    const inputHash   = await hashPassword(pwInput.value.trim());
    const correctHash = await hashPassword(ADMIN_PASSWORD);
    if (inputHash === correctHash) {
      sessionStorage.setItem(SESSION_KEY, 'true');
      closeAdminModal();
      window.location.href = '/interview';
    } else {
      errEl.classList.remove('hidden');
      pwInput.classList.add('border-rose-500');
      pwInput.value = '';
      setTimeout(() => pwInput.classList.remove('border-rose-500'), 1000);
    }
  }

  footerBtn?.addEventListener('click', openAdminModal);
  cancelBtn?.addEventListener('click', closeAdminModal);
  submitBtn?.addEventListener('click', handleAdminSubmit);
  pwInput?.addEventListener('keydown', e => { if (e.key === 'Enter') handleAdminSubmit(); });
  modal?.addEventListener('click', e => { if (e.target === modal) closeAdminModal(); });
</script>

